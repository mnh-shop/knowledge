":[213,213],"#Fitness & Nutrition#Procedure#Offline Calculators#{3}":[214,214],"#Fitness & Nutrition#Procedure#Offline Calculators#{4}":[215,215],"#Fitness & Nutrition#Procedure#Offline Calculators#{5}":[216,216],"#Fitness & Nutrition#Procedure#Offline Calculators#{6}":[217,218],"#Fitness & Nutrition#Procedure#Offline Calculators#{7}":[219,222],"#Fitness & Nutrition#Pitfalls":[223,235],"#Fitness & Nutrition#Pitfalls#{1}":[225,225],"#Fitness & Nutrition#Pitfalls#{2}":[226,226],"#Fitness & Nutrition#Pitfalls#{3}":[227,227],"#Fitness & Nutrition#Pitfalls#{4}":[228,228],"#Fitness & Nutrition#Pitfalls#{5}":[229,229],"#Fitness & Nutrition#Pitfalls#{6}":[230,230],"#Fitness & Nutrition#Pitfalls#{7}":[231,231],"#Fitness & Nutrition#Pitfalls#{8}":[232,233],"#Fitness & Nutrition#Pitfalls#{9}":[234,235],"#Fitness & Nutrition#Verification":[236,243],"#Fitness & Nutrition#Verification#{1}":[238,243],"#Fitness & Nutrition#Quick Reference":[244,256],"#Fitness & Nutrition#Quick Reference#{1}":[246,256]},"outlinks":[],"metadata":{"name":"fitness-nutrition","description":"Gym workout planner and nutrition tracker. Search 690+ exercises by muscle, equipment, or category via wger. Look up macros and calories for 380,000+ foods via USDA FoodData Central. Compute BMI, TDEE, one-rep max, macro splits, and body fat — pure Python, no pip installs. Built for anyone chasing gains, cutting weight, or just trying to eat better.\n","platforms":["linux","macos","windows"],"version":"1.0.0","authors":["haileymarshall"],"license":"MIT","metadata":{"hermes":{"tags":["health","fitness","nutrition","gym","workout","diet","exercise"],"category":"health","prerequisites":{"commands":["curl","python3"]}}},"required_environment_variables":[{"name":"USDA_API_KEY","prompt":"USDA FoodData Central API key (free)","help":"Get one free at https://fdc.nal.usda.gov/api-key-signup/ — or skip to use DEMO_KEY with lower rate limits","required_for":"higher rate limits on food/nutrition lookups (DEMO_KEY works without signup)","optional":true}]},"task_lines":[],"tasks":{},"codeblock_ranges":[[114,126],[128,147],[149,161],[168,188],[190,206]]},"smart_blocks:sources/hermes-agent/optional-skills/health/fitness-nutrition/SKILL.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"861yzm","at":1782387040165},"key":"sources/hermes-agent/optional-skills/health/fitness-nutrition/SKILL.md#---frontmatter---","lines":[1,26],"size":1000,"outlinks":[],"class_name":"SmartBlock"},
