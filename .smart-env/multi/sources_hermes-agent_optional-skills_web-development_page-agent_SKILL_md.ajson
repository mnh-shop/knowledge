s":{},"codeblock_ranges":[[46,48],[54,56],[62,64],[68,83],[106,110],[114,118],[122,126],[130,136],[140,142]]},"smart_blocks:sources/hermes-agent/optional-skills/web-development/page-agent/SKILL.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"102yj9n","at":1782387040231},"key":"sources/hermes-agent/optional-skills/web-development/page-agent/SKILL.md#---frontmatter---","lines":[1,12],"size":923,"outlinks":[],"class_name":"SmartBlock"},
