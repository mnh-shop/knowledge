rs","description":"Fast tokenizers optimized for research and production. Rust-based implementation tokenizes 1GB in <20 seconds. Supports BPE, WordPiece, and Unigram algorithms. Train custom vocabularies, track alignments, handle padding/truncation. Integrates seamlessly with transformers. Use when you need high-performance tokenization or custom tokenizer training.","version":"1.0.0","author":"Orchestra Research","license":"MIT","dependencies":["tokenizers","transformers","datasets"],"platforms":["linux","macos","windows"],"metadata":{"hermes":{"tags":["Tokenization","HuggingFace","BPE","WordPiece","Unigram","Fast Tokenization","Rust","Custom Tokenizer","Alignment Tracking","Production"]}}},"task_lines":[],"tasks":{},"codeblock_ranges":[[42,48],[52,66],[70,93],[99,111],[125,141],[162,180],[200,214],[233,244],[257,268],[281,293],[296,309],[315,328],[339,351],[355,382],[388,405],[411,425],[429,447]]},"smart_blocks:sources/hermes-agent/optional-skills/mlops/huggingface-tokenizers/SKILL.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"1l3bae3","at":1782387040295},"key":"sources/hermes-agent/optional-skills/mlops/huggingface-tokenizers/SKILL.md#---frontmatter---","lines":[1,13],"size":700,"outlinks":[],"class_name":"SmartBlock"},
